<?xml version="1.0" encoding="utf-8"?>
<!-- ========= UNIVERSAL COUNTDOWN WIDGET ==========
     Ein einziges Widget das sich automatisch an alle Größen anpasst!

     Der Android-System ruft onAppWidgetOptionsChanged() auf wenn der
     Benutzer die Widget-Größe verändert. Wir nutzen das um automatisch
     das beste Layout zu wählen.

     Größenbereiche:
     - Ultra-kompakt (4×1): Nur Tage
     - Klein (4×1.5): Tage + Label
     - Mittel (4×2): Titel + Tage + Datum
     - Groß (4×3): Titel + Tage + Monat/Jahre + Datum
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="60dp"
    android:maxResizeWidth="500dp"
    android:maxResizeHeight="500dp"
    android:updatePeriodMillis="900000"
    android:initialLayout="@layout/widget_countdown_medium"
    android:configure="de.beigel.nextime.widget.CountdownWidgetConfigActivity"
    android:description="@string/widget_description"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@drawable/ic_launcher_foreground"
    android:targetCellWidth="4"
    android:targetCellHeight="1" />