<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Farbbalken oben -->
    <ImageView
        android:id="@+id/widget_color_bar_top"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_alignParentTop="true"
        android:background="#FF7043"
        android:contentDescription="Color bar top" />

    <!-- Horizontal Layout für kompakte Anzeige -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_color_bar_top"
        android:layout_above="@id/widget_color_bar_bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <!-- Titel -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Countdown"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <!-- Countdown kompakt (nur Tage) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="42"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/widget_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tage"
                android:textSize="12sp"
                android:textColor="#B0B0B0" />
        </LinearLayout>
    </LinearLayout>

    <!-- Farbbalken unten -->
    <ImageView
        android:id="@+id/widget_color_bar_bottom"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_alignParentBottom="true"
        android:background="#FF7043"
        android:contentDescription="Color bar bottom" />
</RelativeLayout>