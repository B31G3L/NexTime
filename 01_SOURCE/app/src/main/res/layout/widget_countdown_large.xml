<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="0dp">

    <!-- Farbbalken oben -->
    <ImageView
        android:id="@+id/widget_color_bar_top"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentTop="true"
        android:background="#FF7043"
        android:contentDescription="Color bar top" />

    <!-- Hauptinhalt -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_color_bar_top"
        android:layout_above="@id/widget_color_bar_bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Titel -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Countdown"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- Countdown-Anzeige: Tage Stunden Minuten Sekunden -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- Tage -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/widget_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/widget_days_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tage"
                    android:textSize="11sp"
                    android:textColor="#B0B0B0"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stunden -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/widget_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="05"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#E0E0E0" />

                <TextView
                    android:id="@+id/widget_hours_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stunden"
                    android:textSize="11sp"
                    android:textColor="#B0B0B0"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Minuten -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/widget_minutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#C0C0C0" />

                <TextView
                    android:id="@+id/widget_minutes_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minuten"
                    android:textSize="11sp"
                    android:textColor="#B0B0B0"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Sekunden -->
            <LinearLayout
                android:id="@+id/widget_seconds_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_seconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#A0A0A0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sekunden"
                    android:textSize="10sp"
                    android:textColor="#B0B0B0"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Trennlinie - mit FrameLayout umwickelt -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#B0B0B0" />

        <!-- Datum & Zeit Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Datum -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/widget_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 24.12.2025"
                    android:textSize="12sp"
                    android:textColor="#B0B0B0"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Zeit (optional) -->
            <TextView
                android:id="@+id/widget_time_with_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐 18:00 Uhr"
                android:textSize="12sp"
                android:textColor="#B0B0B0"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Farbbalken unten -->
    <ImageView
        android:id="@+id/widget_color_bar_bottom"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentBottom="true"
        android:background="#FF7043"
        android:contentDescription="Color bar bottom" />
</RelativeLayout>