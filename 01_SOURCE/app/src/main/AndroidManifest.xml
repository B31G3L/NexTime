<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexTime"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NexTime">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget Configuration Activity -->
        <activity
            android:name=".widget.CountdownWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.NexTime">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Notification Receiver -->
        <receiver
            android:name=".notifications.NotificationReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Widget Receivers -->
        <receiver
            android:name=".widget.CountdownWidgetReceiver"
            android:exported="true"
            android:label="NexTime Widget Small">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.beigel.nextime.ACTION_UPDATE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/countdown_widget_small_info" />
        </receiver>

        <receiver
            android:name=".widget.CountdownWidgetReceiverMedium"
            android:exported="true"
            android:label="NexTime Widget Medium">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.beigel.nextime.ACTION_UPDATE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android:appwidget.provider"
                android:resource="@xml/countdown_widget_medium_info" />
        </receiver>

        <receiver
            android:name=".widget.CountdownWidgetReceiverLarge"
            android:exported="true"
            android:label="NexTime Widget Large">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.beigel.nextime.ACTION_UPDATE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/countdown_widget_large_info" />
        </receiver>

    </application>

</manifest>